# --- Site URL (optional but recommended) ---
# Used as a fallback for email redirect links when the request origin is
# unavailable. In production set this to your deployed URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Concierge transactional email (Resend) ---
# Create a key at https://resend.com/api-keys. Without it, the /api/concierge
# route accepts the request but skips the confirmation email (dev-friendly).
RESEND_API_KEY=
# Verified sender. Until you verify a domain in Resend you can use the sandbox
# sender "onboarding@resend.dev" (only delivers to your own account email).
CONCIERGE_FROM_EMAIL="WeeFly Concierge <onboarding@resend.dev>"
# Optional: internal address that receives a heads-up for each new lead and is
# used as the reply-to on the client confirmation.
CONCIERGE_TEAM_EMAIL=

# --- Concierge Chatbot · NLP (Anthropic / Claude) ---
# Powers /api/chat/parse — turns free-text messages into a structured flight
# query. Create a key at https://console.anthropic.com/settings/keys.
# Without it, the /newhome chat replies asking for the details it can't parse.
ANTHROPIC_API_KEY=
# Optional: model used for parsing. Defaults to claude-haiku-4-5 (fast + cheap,
# ideal for short extraction). Bump to claude-sonnet-5 if IATA/date resolution
# on less common routes needs more reasoning.
CONCIERGE_NLP_MODEL=claude-haiku-4-5

# --- Concierge Chatbot · Flight search (Amadeus) ---
# Powers /api/flights/search (Flight Offers Search API). Create Self-Service
# credentials at https://developers.amadeus.com. Without them, the search route
# returns realistic MOCK offers so the /newhome flow stays fully demoable.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# Test host by default; switch to https://api.amadeus.com for production keys.
AMADEUS_API_BASE=https://test.api.amadeus.com
# Currency for returned fares (ISO 4217). Defaults to EUR.
AMADEUS_CURRENCY=EUR
