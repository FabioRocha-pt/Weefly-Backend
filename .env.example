# --- Concierge transactional email (Resend) ---
# Create a key at https://resend.com/api-keys. Without it, the /api/concierge
# route accepts the request but skips the confirmation email (dev-friendly).
RESEND_API_KEY=
# Verified sender. Until you verify a domain in Resend you can use the sandbox
# sender "onboarding@resend.dev" (only delivers to your own account email).
CONCIERGE_FROM_EMAIL="WeeFly Concierge <onboarding@resend.dev>"
# Optional: internal address that receives a heads-up for each new lead and is
# used as the reply-to on the client confirmation.
CONCIERGE_TEAM_EMAIL=
